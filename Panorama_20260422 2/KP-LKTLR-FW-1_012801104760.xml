          <ethernet/>
          <loopback>
            <units/>
          </loopback>
          <vlan>
            <units/>
          </vlan>
        </interface>
        <profiles>
          <monitor-profile/>
          <interface-management-profile>
            <entry name="Management">
              <http>no</http>
              <https>yes</https>
              <ssh>yes</ssh>
              <ping>yes</ping>
              <telnet>no</telnet>
