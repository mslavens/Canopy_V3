  <devices>
    <entry name="localhost.localdomain">
      <network>
        <interface>
          <ethernet/>
        </interface>
        <profiles>
          <monitor-profile/>
          <interface-management-profile/>
        </profiles>
        <ike>
          <crypto-profiles>
            <ike-crypto-profiles/>
            <ipsec-crypto-profiles/>
            <global-protect-app-crypto-profiles/>
          </crypto-profiles>
        </ike>
        <qos>
          <profile/>
        </qos>
        <virtual-router/>
      </network>
      <deviceconfig>
        <system>
          <motd-and-banner>
            <motd-enable>yes</motd-enable>
            <message>Unauthorized use or access is strictly prohibited and may result in civil action or criminal prosecution.</message>
          </motd-and-banner>
          <hostname>KP-LIBRT-FW-2</hostname>
          <ip-address>10.45.39.135</ip-address>
          <netmask>255.255.255.240</netmask>
          <locale>en</locale>
          <default-gateway>10.45.39.129</default-gateway>
          <device-telemetry>
            <device-health-performance>yes</device-health-performance>
            <product-usage>yes</product-usage>
            <threat-prevention>yes</threat-prevention>
            <region>Americas</region>
          </device-telemetry>
          <snmp-setting>
            <access-setting>
              <version>
                <v2c>
                  <snmp-community-string>R7oUZ9bT2Zg4iJ</snmp-community-string>
                </v2c>
              </version>
            </access-setting>
          </snmp-setting>
        </system>
        <high-availability>
          <group>
            <description>KP-LIBRT-FW-2</description>
            <peer-ip>10.45.39.209</peer-ip>
            <peer-ip-backup>10.45.39.213</peer-ip-backup>
            <mode>
              <active-passive>
                <passive-link-state>auto</passive-link-state>
              </active-passive>
            </mode>
            <election-option>
              <heartbeat-backup>yes</heartbeat-backup>
              <preemptive>no</preemptive>
              <timers>
                <recommended/>
              </timers>
            </election-option>
            <state-synchronization>
              <transport>ethernet</transport>
            </state-synchronization>
            <monitoring>
              <link-monitoring>
                <link-group>
                  <entry name="KP-LIBRT-MON">
                    <interface>
                      <member>ethernet1/1</member>
                      <member>ethernet1/2</member>
                    </interface>
                  </entry>
                </link-group>
              </link-monitoring>
            </monitoring>
          </group>
          <interface>
            <ha1>
              <port>ethernet1/6</port>
              <ip-address>10.45.39.210</ip-address>
              <netmask>255.255.255.252</netmask>
            </ha1>
            <ha1-backup>
              <port>ethernet1/7</port>
              <ip-address>10.45.39.214</ip-address>
              <netmask>255.255.255.252</netmask>
            </ha1-backup>
            <ha2>
              <port>ethernet1/8</port>
              <ip-address>10.45.39.218</ip-address>
              <netmask>255.255.255.252</netmask>
            </ha2>
          </interface>
          <enabled>yes</enabled>
        </high-availability>
      </deviceconfig>
      <vsys>
        <entry name="vsys1">
          <application/>
          <application-group/>
          <zone>
            <entry name="trust">
              <network>
                <virtual-wire/>
              </network>
            </entry>
          </zone>
          <service/>
          <service-group/>
          <schedule/>
          <rulebase/>
          <import>
            <network>
              <interface/>
            </network>
          </import>
        </entry>
      </vsys>
    </entry>
  </devices>
</config>
